# ============================================================
# PRODE Mundial 2026 — variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# `.env.local` está en .gitignore: NO se commitea.
# ============================================================

# ---- Supabase ----
# Con Supabase local (`npm run db:start`), la CLI imprime estos valores.
# URL de la API (local por defecto: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# anon key (pública, segura para el cliente — protegida por RLS).
# La imprime `supabase start` / `supabase status`.
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key-de-supabase-status>"

# service-role key (SECRETA — solo servidor/scripts, bypassa RLS).
# Se usa para crear usuarios (npm run seed:users). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key-de-supabase-status>"

# ---- Gemini (IA de texto — features aún NO implementadas) ----
# Dejar vacío por ahora; el wrapper está preparado pero sin uso.
GEMINI_API_KEY=""

# ---- Seed de usuarios (opcional, para scripts/seed-users.ts) ----
# Contraseña por defecto que se asigna a los usuarios sembrados.
SEED_DEFAULT_PASSWORD="prode2026"

# ---- Cron (job de mensajes diarios) ----
# Secreto que valida el endpoint /api/cron/daily-messages. En Vercel, definí
# CRON_SECRET y la plataforma lo manda como `Authorization: Bearer <secret>`.
# Vacío en local = sin validación (el script npm run job:daily no lo usa).
CRON_SECRET=""
